                                         "language":  "javaScript",
                                         "jsCode":  "// === [BC44 Pipeline] RAG Chat (mock) ===\nconst WORKFLOW_TYPE = \u0027rag_chat\u0027;\nconst PIPELINE_MODE = $env.PIPELINE_MODE || \u0027mock\u0027;\nconst input = $input.first().json;\nconst headers = input.headers || {};\nconst body = input.body || {};\nconst expectedToken = $env.N8N_WEBHOOK_TOKEN || \u0027dev-local-token\u0027;\nconst callbackToken = $env.BASE44_CALLBACK_TOKEN || \u0027dev-callback-token\u0027;\nconst request_id  = body.request_id || headers[\u0027x-request-id\u0027] || null;\nconst project_id  = body.project_id || headers[\u0027x-project-id\u0027] || null;\nconst user_id     = body.user_id    || headers[\u0027x-user-id\u0027]    || null;\nconst callback_url = body.callback_url || $env.BASE44_CALLBACK_URL || \u0027http://localhost:4000/mock-callback\u0027;\nconst execId = (typeof $execution !== \u0027undefined\u0027 \u0026\u0026 $execution.id) ? String($execution.id) : \u0027manual\u0027;\nfunction envelope(status, progress, result, error) { return [{ json: { callback_url, callback_token: callbackToken, payload: { request_id, workflow_type: WORKFLOW_TYPE, project_id, status, progress, result, error, n8n_execution_id: execId } } }]; }\nfunction fail(code, node, message, details) { return envelope(\u0027failed\u0027, 0, null, { message, node, code, details: details || {} }); }\nlet step = \u0027Validate Token\u0027;\ntry {\n  const auth = headers[\u0027authorization\u0027] || headers[\u0027Authorization\u0027] || \u0027\u0027;\n  const token = String(auth).replace(/^Bearer\\s+/i, \u0027\u0027).trim();\n  if (!token || token !== expectedToken) return fail(\u0027AUTH_ERROR\u0027, step, \u0027Invalid or missing bearer token\u0027);\n  step = \u0027Validate Payload\u0027;\n  const missing = [];\n  if (!request_id) missing.push(\u0027request_id\u0027);\n  if (!project_id) missing.push(\u0027project_id\u0027);\n  if (!user_id) missing.push(\u0027user_id\u0027);\n  if (!body.question) missing.push(\u0027question\u0027);\n  if (missing.length) return fail(\u0027VALIDATION_ERROR\u0027, step, \u0027Missing required fields: \u0027 + missing.join(\u0027, \u0027), { missing });\n  if (PIPELINE_MODE === \u0027live\u0027) { return fail(\u0027INTERNAL_ERROR\u0027, \u0027Vector Search\u0027, \u0027live mode not yet wired - set PIPELINE_MODE=mock\u0027); }\n  step = \u0027Vector Search\u0027;\n  step = \u0027LLM Route\u0027;\n  const result = { answer: \u0027[MOCK] 핵심 요구사항: 실시간 모니터링, 99.9% 가용성, 개인정보 암호화.\u0027, confidence: \u0027document_based\u0027, citations: [{ document_id: (Array.isArray(body.document_filter) \u0026\u0026 body.document_filter[0]) || \u0027DOC-001\u0027, file_name: \u0027RFP.pdf\u0027, page: 12, section: \u00273.2 주요 요구사항\u0027, chunk_id: \u0027chunk_0045\u0027, score: 0.87, excerpt: \u0027...\u0027 }], model_used: \u0027mock-local-sllm\u0027, usage: { input_tokens: 2200, output_tokens: 680 }, mode: \u0027mock\u0027 };\n  return envelope(\u0027success\u0027, 100, result, null);\n} catch (e) { return fail(\u0027INTERNAL_ERROR\u0027, step, (e \u0026\u0026 e.message) ? e.message : String(e)); }"
                                     }
