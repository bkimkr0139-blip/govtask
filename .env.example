# =====================================================================
# Base44 <-> n8n AI 파이프라인 환경변수 (.env.example)
# 복사: cp .env.example .env  후 값 채우기
# =====================================================================

# --- n8n core ---------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# 외부 공개 URL (ngrok/cloudflared 터널). Base44에는 이 값을 N8N_BASE_URL로 전달.
# 로컬 native n8n을 쓰는 경우에도 webhook 절대 URL 생성을 위해 설정 권장.
WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
# Code 노드에서 $env 접근 허용 (token 검증에 필요). false=허용.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
GENERIC_TIMEZONE=Asia/Seoul

# --- 외부 공개 URL (Base44에 전달하는 값) -----------------------------
# Base44 측 .env 또는 연동설정에 N8N_BASE_URL 로 등록한다.
# 예) https://<random>.ngrok-free.app  또는  https://<sub>.trycloudflare.com
N8N_BASE_URL=https://CHANGE-ME.ngrok-free.app
N8N_PROXY_URL=https://CHANGE-ME.ngrok-free.app

# --- 웹훅 인증 (모든 workflow 공통 Bearer) ---------------------------
# 미설정 시 workflow는 'dev-local-token' 으로 폴백(개발용).
N8N_WEBHOOK_TOKEN=dev-local-token

# --- Base44 callback ---------------------------------------------------
# 요청 payload의 callback_url 이 우선. 없으면 아래 기본값 사용.
BASE44_BASE_URL=https://app.base44.com
BASE44_CALLBACK_URL=http://localhost:4000/mock-callback
BASE44_CALLBACK_TOKEN=dev-callback-token

# --- Vector DB (Qdrant) — 미가동: mock 모드 -------------------------
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
VECTOR_COLLECTION_PREFIX=project_

# --- Object Storage — 미구성: mock 모드 ------------------------------
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=/storage/files
S3_ENDPOINT=
S3_BUCKET=ai-project-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- MCP Gateway — 미구현: mock 모드 ---------------------------------
MCP_GATEWAY_URL=http://localhost:8088
INTERNAL_API_TOKEN=dev-internal-token

# --- LLM ---------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LOCAL_SLLM_BASE_URL=http://localhost:11434/v1
LOCAL_SLLM_MODEL=qwen2.5:14b
DEFAULT_LLM_PROVIDER=local
DEFAULT_EMBEDDING_MODEL=bge-m3

# --- 파이프라인 동작 플래그 ------------------------------------------
# mock=실제 외부서비스 호출 없이 contract 형태의 모의 응답 생성 (현재 기본)
# live=Qdrant/LLM/MCP Gateway 실제 호출
PIPELINE_MODE=mock
